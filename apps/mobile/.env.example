# AgentSpace mobile — environment config.
#
# These are all EXPO_PUBLIC_* vars: Expo **inlines them into the app bundle at build
# time**, so they are NON-SECRET by design (never put a real secret in an
# EXPO_PUBLIC_ var). On your build machine, copy this file and fill it in:
#
#   cp apps/mobile/.env.example apps/mobile/.env.local
#
# `.env.local` is gitignored. Expo reads it automatically (`expo start` / `expo export`).

# SpacetimeAuth (OIDC) — the public client_id from the SpacetimeAuth dashboard (SETUP.md S-1).
# Requires the dashboard client to be a PUBLIC client (PKCE, no secret) with redirect
# URI `agentspace://redirect` and the `offline_access` scope enabled.
EXPO_PUBLIC_SPACETIMEAUTH_CLIENT_ID=client_033XyhtPkMcEQ4adazN6Cx

# Target SpacetimeDB. Maincloud trusts the SpacetimeAuth issuer (a local server does not),
# so login + the agent reply loop must run against Maincloud (SETUP.md S-3).
EXPO_PUBLIC_SPACETIMEDB_HOST=wss://maincloud.spacetimedb.com
EXPO_PUBLIC_SPACETIMEDB_DB_NAME=agentspace-hpm58

# Optional override (default issuer is already correct; set only to point elsewhere):
# EXPO_PUBLIC_SPACETIMEAUTH_ISSUER=https://auth.spacetimedb.com/oidc

# Google sign-in (M2.9, DEC-037) — the WEB OAuth client ID from Google Cloud Console
# (SETUP.md S-9). Public (an EXPO_PUBLIC_ var); it makes Google mint the id token and is
# the `aud` the module verifies. Until set, "Continue with Google" stays inert. The
# ANDROID client ID is used by the native SDK (next chunk). No native wiring ships yet.
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# --- Local dev (instead of Maincloud) ---
# For a local `spacetime start` server (note: local servers don't trust the OIDC issuer,
# so login is Maincloud-only; local is for the anonymous/dev path):
# EXPO_PUBLIC_SPACETIMEDB_HOST=ws://10.0.2.2:3000   # Android emulator alias for host localhost
# EXPO_PUBLIC_SPACETIMEDB_DB_NAME=agentspace
