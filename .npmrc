# Flat node_modules so Metro (Expo / React Native) can resolve transitive deps
# under a pnpm monorepo. This is Expo's recommended setting for pnpm workspaces;
# without it Metro fails to resolve packages like expo-modules-core.
node-linker=hoisted

# Allow esbuild (vitest) to run its install script.
# (mirrors package.json#pnpm.onlyBuiltDependencies for environments that read .npmrc)
